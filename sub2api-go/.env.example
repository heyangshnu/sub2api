# Sub2API 环境变量模板
# 复制为 .env 并填入实际值（勿将真实密钥提交到 Git）

# 服务端口
PORT=3000

# 生产环境必须设置 APP_ENV=production 并配合强密钥（见 ValidateProductionSecrets）
# APP_ENV=development

# 管理员 API Key（自定义）
ADMIN_KEY=sk-admin-your-secret-key

# JWT 密钥（随机生成；生产至少 32 字符）
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Redis 连接（cmd/server 使用此变量；生产必须可用）
REDIS_URL=redis://localhost:6379

# 反代 IP 段（逗号分隔 CIDR），供 Gin 解析 X-Forwarded-For；生产有 Nginx 时务必配置
# TRUSTED_PROXIES=127.0.0.1/32,10.0.0.0/8

# Redis 不可用时是否允许退回到内存存储（仅开发；生产无 Redis 会直接退出）
# ALLOW_MEMORY_STORE=true

# API 限流依赖 Redis：Redis 故障时 true=放行 false=503
# RATE_LIMIT_REDIS_FAIL_OPEN=true

# 未在价目表中的模型：true=按默认单价估算（旧行为） false=拒绝请求
# ALLOW_UNKNOWN_MODEL_PRICING=true

# Stripe 支付（从 Stripe Dashboard 获取）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 注册邀请码（空则不需要）
INVITE_CODE=cloudtoken2026

# 注册邮箱验证码（true 时须配置 SMTP）
EMAIL_VERIFY_ENABLED=false
# SMTP：密码为邮箱「客户端授权码」等，勿使用示例占位符以外的真实值写入仓库
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# 上游 API（按需配置）
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
